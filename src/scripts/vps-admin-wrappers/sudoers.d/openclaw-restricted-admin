# /etc/sudoers.d/openclaw-restricted-admin
#
# Narrowly scoped root wrappers for the `openclaw` user (Gregor bot).
# All commands are hardcoded paths with NO user-controlled arguments.
#
# Preserves isolation from the demos / demos-node account and its home
# directory — no wrapper accepts a path argument, no wrapper invokes a
# shell or a generic systemctl/journalctl/apt command.
#
# **demos-node has 100% priority on this host. openclaw is a sidekick
# only.** Explicitly NO wrappers for starting, stopping, restarting,
# or reading logs from demos-node — openclaw must not be able to
# disturb or observe demos in any way. Demos boundary is inviolable.
#
# Install via /home/mj/projects/openclaw-bot/src/scripts/vps-admin-wrappers/install-wrappers.sh
# (from a root shell). Do NOT edit by hand — regenerate from the repo.

Defaults:openclaw  env_reset, mail_badpass, use_pty, !authenticate
Defaults:openclaw  secure_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/snap/bin"

# --- host introspection (read-only, non-disturbing) ---
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-system-status
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-firewall-status
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-system-upgrade

# --- install-phase wrappers (safe to revoke after Gregor install completes) ---
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-install-nodejs
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-install-ufw

# --- firewall ---
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-ufw-allow-ssh
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-ufw-default-deny

# --- systemd unit management (Gregor gateway only) ---
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-install-unit
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-install-hardening
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-gateway-start
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-gateway-stop
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-gateway-restart
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-gateway-enable
openclaw ALL=(root) NOPASSWD: /usr/local/sbin/openclaw-gateway-logs
