# Crabbox sync excludes for openclaw-bot.
# Patterns use the same matcher as sync.exclude in .crabbox.yaml.
# Crabbox already excludes .git, node_modules, .ignored, .vite,
# playwright-report, test-results, .crabbox — list ONLY repo-specific
# exclusions here.

# Local Interceptor screenshots — nonignored untracked, would otherwise sync.
interceptor-screenshot-*.png
interceptor-screenshot-*.jpg

# Saved implementation plans — gitignored already, but defensive.
Plans/

# Session docs — auto-generated, gitignored already, but defensive.
.sessions/

# Local VPS audit JSON / report artifacts — generated by src/scripts/.
audit-vps-*.json
audit-vps-*.report.txt

# Local crabbox install staging if it ever lands in-repo.
crabbox_*_linux_amd64.tar.gz
crabbox
